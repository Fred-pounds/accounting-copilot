      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:states:eu-west-1:280250685594:stateMachine:accounting-copilot-document-processing",
            "creation_date": "2026-03-08T15:25:07Z",
            "definition": "{\"Comment\":\"Process uploaded financial document\",\"StartAt\":\"ExtractText\",\"States\":{\"CheckConfidence\":{\"Choices\":[{\"Next\":\"ReconcileReceipts\",\"NumericGreaterThanEquals\":0.7,\"Variable\":\"$.classification_result.Payload.confidence\"}],\"Default\":\"FlagForReview\",\"Type\":\"Choice\"},\"ClassifyTransaction\":{\"Next\":\"ValidateData\",\"Parameters\":{\"FunctionName\":\"accounting-copilot-transaction-classifier\",\"Payload\":{\"document_id.$\":\"$.document_id\",\"extracted_data.$\":\"$.ocr_result.Payload\",\"user_id.$\":\"$.user_id\"}},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":\"$.classification_result\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.TaskFailed\"],\"IntervalSeconds\":2,\"MaxAttempts\":3}],\"Type\":\"Task\"},\"ExtractText\":{\"Catch\":[{\"ErrorEquals\":[\"OCRFailure\",\"States.TaskFailed\"],\"Next\":\"NotifyOCRFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"ClassifyTransaction\",\"Parameters\":{\"FunctionName\":\"accounting-copilot-ocr-processor\",\"Payload\":{\"document_id.$\":\"$.document_id\",\"s3_bucket.$\":\"$.s3_bucket\",\"s3_key.$\":\"$.s3_key\",\"user_id.$\":\"$.user_id\"}},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":\"$.ocr_result\",\"Type\":\"Task\"},\"FlagForReview\":{\"Next\":\"NotifyPendingApproval\",\"Parameters\":{\"ExpressionAttributeNames\":{\"#status\":\"status\"},\"ExpressionAttributeValues\":{\":flagged\":{\"BOOL\":true},\":status\":{\"S\":\"pending_review\"}},\"Key\":{\"PK\":{\"S.$\":\"States.Format('USER#{}', $.user_id)\"},\"SK\":{\"S.$\":\"States.Format('TXN#{}', $.classification_result.Payload.transaction_id)\"}},\"TableName\":\"AccountingCopilot\",\"UpdateExpression\":\"SET #status = :status, flagged_for_review = :flagged\"},\"Resource\":\"arn:aws:states:::dynamodb:updateItem\",\"ResultPath\":\"$.flag_result\",\"Type\":\"Task\"},\"LogAuditTrail\":{\"End\":true,\"Parameters\":{\"FunctionName\":\"accounting-copilot-audit-logger\",\"Payload\":{\"action_type\":\"document_processing\",\"document_id.$\":\"$.document_id\",\"transaction_id.$\":\"$.classification_result.Payload.transaction_id\",\"user_id.$\":\"$.user_id\",\"workflow_result\":{\"classification.$\":\"$.classification_result.Payload\",\"ocr_status.$\":\"$.ocr_result.Payload.status\",\"reconciliation.$\":\"$.reconciliation_result.Payload\",\"validation.$\":\"$.validation_result.Payload\"}}},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":\"$.audit_result\",\"Type\":\"Task\"},\"NotifyOCRFailure\":{\"End\":true,\"Parameters\":{\"Message\":{\"default.$\":\"States.Format('OCR processing failed for document {}. Manual entry required.', $.document_id)\"},\"Subject\":\"OCR Processing Failed\",\"TopicArn\":\"arn:aws:sns:eu-west-1:280250685594:accounting-copilot-ocr-failures\"},\"Resource\":\"arn:aws:states:::sns:publish\",\"Type\":\"Task\"},\"NotifyPendingApproval\":{\"Next\":\"ReconcileReceipts\",\"Parameters\":{\"Message\":{\"default.$\":\"States.Format('Transaction {} requires review. Confidence: {}', $.classification_result.Payload.transaction_id, $.classification_result.Payload.confidence)\"},\"Subject\":\"Transaction Pending Review\",\"TopicArn\":\"arn:aws:sns:eu-west-1:280250685594:accounting-copilot-pending-approvals\"},\"Resource\":\"arn:aws:states:::sns:publish\",\"ResultPath\":\"$.notification_result\",\"Type\":\"Task\"},\"ReconcileReceipts\":{\"Next\":\"LogAuditTrail\",\"Parameters\":{\"FunctionName\":\"accounting-copilot-reconciliation-engine\",\"Payload\":{\"transaction_id.$\":\"$.classification_result.Payload.transaction_id\",\"user_id.$\":\"$.user_id\"}},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":\"$.reconciliation_result\",\"Type\":\"Task\"},\"ValidateData\":{\"Next\":\"CheckConfidence\",\"Parameters\":{\"FunctionName\":\"accounting-copilot-data-validator\",\"Payload\":{\"transaction_id.$\":\"$.classification_result.Payload.transaction_id\",\"user_id.$\":\"$.user_id\"}},\"Resource\":\"arn:aws:states:::lambda:invoke\",\"ResultPath\":\"$.validation_result\",\"Type\":\"Task\"}}}",
